{
  "rewrites": [
    { "source": "/silicone-render/", "destination": "/index.html" },
    { "source": "/monocouche-render/", "destination": "/index.html" },
    { "source": "/external-wall-insulation/", "destination": "/index.html" },
    { "source": "/internal-plastering/", "destination": "/index.html" },
    { "source": "/dry-lining/", "destination": "/index.html" },
    { "source": "/services/", "destination": "/index.html" },
    { "source": "/portfolio/", "destination": "/index.html" },
    { "source": "/how-we-apply/", "destination": "/index.html" },
    { "source": "/pricing/", "destination": "/index.html" },
    { "source": "/warranties/", "destination": "/index.html" },
    { "source": "/faq/", "destination": "/index.html" },
    { "source": "/contact/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/app.min.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/react.production.min.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/react-dom.production.min.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
